  <property name="styleSheet">
   <string notr="true">
QMainWindow {
    background-color: #0b0d12;
}

QWidget#centralwidget {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #0e1118, stop:1 #0b0d12);
}

QPlainTextEdit {
    background-color: #11141d;
    color: #e8dfc9;
    selection-background-color: #3f2e1a;
    selection-color: #ffd700;
    border: 1px solid #1e212e;
    border-radius: 10px;
    padding: 12px;
    font-family: &quot;JetBrains Mono&quot;, &quot;Consolas&quot;, monospace;
    font-size: 14px;
}

QMenuBar {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #14171f, stop:1 #0e1118);
    color: #d4b67d;
    border-bottom: 1px solid #1e212e;
}

QMenuBar::item {
    background: transparent;
    padding: 8px 16px;
}

QMenuBar::item:selected {
    background: #2a2e3c;
    color: #f0d4a2;
}

QMenu {
    background-color: #11141d;
    color: #e8dfc9;
    border: 1px solid #2a2e3c;
    border-radius: 6px;
}

QMenu::item {
    padding: 8px 32px 8px 36px;
}

QMenu::item:selected {
    background-color: #3f2e1a;
    color: #ffd700;
}

QToolBar {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #14171f, stop:1 #0e1118);
    border: none;
    border-bottom: 1px solid #1e212e;
    padding: 6px 12px;
    spacing: 8px;
}

QToolBar::separator {
    background: #2a2e3c;
    width: 1px;
    margin-left: 4px;
    margin-right: 4px;
}

QToolButton {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    padding: 6px;
    color: #d4b67d;
    font-size: 13px;
}

QToolButton:hover {
    background: #1e212e;
    border: 1px solid #3f2e1a;
    color: #f0d4a2;
}

QToolButton:pressed {
    background: #2a2e3c;
    border: 1px solid #4a3c1f;
}

QStatusBar {
    background: #0e1118;
    color: #a89b7c;
    border-top: 1px solid #1e212e;
    font-size: 12px;
    padding: 4px 8px;
}
   </string>
